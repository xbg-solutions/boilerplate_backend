# ──────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────
APP_NAME=my-backend-api
APP_VERSION=1.0.0
NODE_ENV=development
PORT=5001

# ──────────────────────────────────────────────────────────
# Firebase
# ──────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id

# ──────────────────────────────────────────────────────────
# Database
#
# Multi-DB (recommended): use separate database IDs
#   MAIN_DATABASE_ID=main
#   ANALYTICS_DATABASE_ID=analytics
#
# Single-DB: set both to (default)
#   MAIN_DATABASE_ID=(default)
#   ANALYTICS_DATABASE_ID=(default)
# ──────────────────────────────────────────────────────────
MAIN_DATABASE_ID=main
ANALYTICS_DATABASE_ID=analytics
# DB_RETRY_ATTEMPTS=3
# DB_RETRY_DELAY=1000
# DB_TIMEOUT=10000
# DB_ENABLE_CACHE=true

# Uncomment for local development with emulator:
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ──────────────────────────────────────────────────────────
# API
# ──────────────────────────────────────────────────────────
API_BASE_PATH=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
REQUEST_SIZE_LIMIT=10mb
# ENABLE_SWAGGER=true

# ──────────────────────────────────────────────────────────
# Features
# ──────────────────────────────────────────────────────────
FEATURE_AUTHENTICATION=true
FEATURE_MULTI_TENANT=false
FEATURE_FILE_UPLOADS=true
FEATURE_NOTIFICATIONS=true
FEATURE_ANALYTICS=false
FEATURE_REALTIME=true

# ──────────────────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ──────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────
LOG_LEVEL=info

# ──────────────────────────────────────────────────────────
# PII Encryption
# Required for AES-256-GCM PII encryption (hashValue/hashFields).
# Generate with: openssl rand -hex 32
# ──────────────────────────────────────────────────────────
PII_ENCRYPTION_KEY=

# ──────────────────────────────────────────────────────────
# JWT / Authentication
# ──────────────────────────────────────────────────────────
JWT_ISSUER=my-backend-api
JWT_AUDIENCE=my-backend-api-api
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
TOKEN_BLACKLIST_ENABLED=true
TOKEN_BLACKLIST_CLEANUP_INTERVAL=3600000
TOKEN_BLACKLIST_RETENTION_DAYS=30

# ──────────────────────────────────────────────────────────
# Integrations (uncomment and configure as needed)
# ──────────────────────────────────────────────────────────
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=mailjet
# MAILJET_API_KEY=
# MAILJET_SECRET_KEY=

# SMS_ENABLED=true
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# CRM_ENABLED=true
# CRM_PROVIDER=hubspot
# HUBSPOT_API_KEY=

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Auth Providers (optional — Firebase is the default)
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# CLERK_API_KEY=

# ──────────────────────────────────────────────────────────
# Cache (disabled by default)
# ──────────────────────────────────────────────────────────
# CACHE_ENABLED=false
# CACHE_DEFAULT_PROVIDER=memory
# CACHE_DEFAULT_TTL=300
# CACHE_NAMESPACE=v1
