import { Firestore, DocumentData } from 'firebase-admin/firestore';
import { BaseRepository } from '@xbg.solutions/backend-core';
{{#if isSubcollection}}
import { IScopedRepository, FirestoreScopedRepository } from '@xbg.solutions/backend-core';
{{/if}}
import { {{entityName}} } from '../entities/{{entityName}}';

export class {{entityName}}Repository extends BaseRepository<{{entityName}}> {
  protected collectionName = '{{collectionName}}';
{{#if isSubcollection}}
  protected subcollectionName = '{{subcollectionName}}';
{{/if}}

  constructor(db: Firestore) {
    super(db);
  }

  /**
   * Convert Firestore document to entity
   */
  protected fromFirestore(id: string, data: DocumentData): {{entityName}} {
    return {{entityName}}.fromFirestore(id, data);
  }

{{#if isSubcollection}}
  /**
   * Create a scoped repository for {{entityName}} under a specific {{parentEntity}}.
   *
   * Usage:
   *   const repo = {{entityNameLower}}Repository.scopedTo({{parentEntityLower}}Id);
   *   const items = await repo.findAll();
   */
  scopedTo({{parentEntityLower}}Id: string): IScopedRepository<{{entityName}}> {
    return new FirestoreScopedRepository<{{entityName}}>(
      this.db,
      ['{{collectionName}}', {{parentEntityLower}}Id, '{{subcollectionName}}'],
      (id: string, data: Record<string, any>) => this.fromFirestore(id, data)
    );
  }
{{/if}}

{{#each fields}}
{{#if unique}}
  /**
   * Find {{../../entityName}} by {{name}}
   */
  async findBy{{capitalize name}}({{name}}: {{{tsType}}}): Promise<{{../../entityName}} | null> {
    const snapshot = await this.getCollection()
      .where('{{name}}', '==', {{name}})
      .where('deletedAt', '==', null)
      .limit(1)
      .get();

    if (snapshot.empty) {
      return null;
    }

    const doc = snapshot.docs[0];
    return this.fromFirestore(doc.id, doc.data());
  }
{{/if}}
{{/each}}

